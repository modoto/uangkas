FLASK_ENV=development
SECRET_KEY=ganti-dengan-string-acak-yang-panjang

# Database — pilih salah satu
# SQLite (development, tidak perlu install):
DATABASE_URL=sqlite:///uangkas.db

# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/uangkas

# Email (SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=Uang Kas <your-email@gmail.com>

# URL aplikasi (untuk magic link di email)
APP_BASE_URL=http://localhost:5000

# Email owner (satu-satunya yang bisa login sebagai owner)
OWNER_EMAIL=setyanaputra@yahoo.com
