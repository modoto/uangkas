{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flask: Run (Development)",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "args": ["run", "--debug", "--port", "5000"],
      "env": {
        "FLASK_APP": "app.py",
        "FLASK_ENV": "development",
        "FLASK_DEBUG": "1",
        "PYTHONDONTWRITEBYTECODE": "1"
      },
      "envFile": "${workspaceFolder}/.env",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "python": "C:\\Users\\User\\AppData\\Local\\Python\\pythoncore-3.14-64\\python.exe",
      "justMyCode": true
    },
    {
      "name": "Flask: Run (Step into libraries)",
      "type": "debugpy",
